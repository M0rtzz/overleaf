extends ../layout-marketing

include ../_mixins/notification

block vars
	- isWebsiteRedesign = false
	- forceLightMarketingNavbar = true

block content
	main#main-content.content.content-alt.auth-theme-page
		.container
			.row
				.col-lg-8.offset-lg-2.col-xl-6.offset-xl-3
					.card.login-register-surface-card
						.card-body
							.page-header.login-register-page-header
								h1.login-register-header-heading-focus(style='font-family: Merriweather, serif; margin-bottom: 12.5px !important;') #{translate("reset_your_password")}
								.login-register-hr-text-container(style='margin-top: 1px; padding: 5px 0;')

							form(
								name='passwordResetForm'
								data-ol-async-form
								action='/user/password/set'
								method='POST'
								data-ol-hide-on-error='token-expired'
								style='margin-top: 0px !important;'
							)
								div(hidden data-ol-sent)
									+notification({
										ariaLive: 'polite',
										type: 'success',
										className: 'auth-theme-success-notification mb-3',
										title: translate('password_updated'),
										content: translate('your_password_has_been_successfully_changed') + '.'
									})
									p.text-center(style='margin-bottom: 0; font-family: Lato, sans-serif;')
										a(href='/login') #{translate('log_in_now')}

								div(data-ol-not-sent)
									p(style='margin-top: 0px; margin-bottom: 15px !important; font-family: Lato, sans-serif; color: var(--content-primary-themed);' data-ol-hide-on-error-message='token-expired')
										| #{translate("create_a_new_password_for_your_account")}.
									+formMessagesNewStyle

									+customFormMessageNewStyle('password-contains-email', 'danger')
										| #{translate('invalid_password_contains_email')}
										| #{translate('use_a_different_password')}.

									+customFormMessageNewStyle('password-too-similar', 'danger')
										| #{translate('invalid_password_too_similar')}
										| #{translate('use_a_different_password')}.

									+customFormMessageNewStyle('token-expired', 'danger')
										| #{translate('password_reset_token_expired')}
										br
										a(href='/user/password/reset')
											| #{translate('request_new_password_reset_email')}

									input(name='_csrf' type='hidden' value=csrfToken)
									input(name='email' type='text' hidden autocomplete='username' value=email)

									.form-group
										label(
											for='passwordField'
											data-ol-hide-on-error-message='token-expired'
											style='font-family: Lato, sans-serif; margin-bottom: 0.5em;'
										) #{translate("new_password")}
										input#passwordField.form-control.auth-aux-new-password(
											name='password'
											type='password'
											autocomplete='new-password'
											autofocus
											required
											minlength=settings.passwordStrengthOptions.length.min
											style='font-family: Lato, sans-serif !important; height: 45px !important; border-radius: 20px !important; padding: 10px 15px !important; border: 1px solid var(--border-primary-themed) !important; background-color: var(--bg-tertiary-themed) !important; color: var(--content-primary-themed) !important;'
										)

										+customValidationMessageNewStyle('invalid-password')
											| #{translate('invalid_password')}.

										+customValidationMessageNewStyle('password-must-be-different')
											| #{translate('password_cant_be_the_same_as_current_one')}

										+customValidationMessageNewStyle('password-must-be-strong')
											| !{translate('password_was_detected_on_a_public_list_of_known_compromised_passwords', {}, [{name: 'a', attrs: {href: 'https://haveibeenpwned.com/passwords', rel: 'noopener noreferrer', target: '_blank'}}])}
											| #{translate('use_a_different_password')}.

										input(name='passwordResetToken' type='hidden' value=passwordResetToken)
									div(data-ol-hide-on-error-message='token-expired')
										p(style='margin-top: 10px; margin-bottom: 8px; font-family: Lato, sans-serif; color: var(--content-primary-themed);')
											| #{translate('in_order_to_have_a_secure_account_make_sure_your_password')}
										ul.mb-3.ps-4(style='font-family: Lato, sans-serif; color: var(--content-primary-themed);')
											li #{translate('is_longer_than_n_characters', {n: settings.passwordStrengthOptions.length.min})}
											li #{translate('does_not_contain_or_significantly_match_your_email')}
											li #{translate('is_not_used_on_any_other_website')}
									.actions
										button.btn.btn-primary.w-100(
											type='submit'
											data-ol-disabled-inflight
											aria-label=translate('set_new_password')
											style='font-family: Lato, sans-serif; padding: 10px 25px; border-radius: 20px;'
										)
											span(data-ol-inflight='idle')
												| #{translate('set_new_password')}
											span(hidden data-ol-inflight='pending')
												| #{translate('set_new_password')}…
