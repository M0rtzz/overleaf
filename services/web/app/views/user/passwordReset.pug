extends ../layout-marketing
include ../_mixins/recaptcha
include ../_mixins/notification

block vars
	- isWebsiteRedesign = false
	- forceLightMarketingNavbar = true

block content
	- var showCaptcha = settings.recaptcha && settings.recaptcha.siteKey && !(settings.recaptcha.disabled && settings.recaptcha.disabled.passwordReset)

	if showCaptcha
		script(
			type='text/javascript'
			nonce=scriptNonce
			src='https://www.recaptcha.net/recaptcha/api.js?render=explicit'
		)
		div(
			id='recaptcha'
			class='g-recaptcha'
			data-sitekey=settings.recaptcha.siteKey
			data-size='invisible'
			data-badge='inline'
		)

	main#main-content.content.content-alt.auth-theme-page(data-ol-captcha-retry-trigger-area='')
		.container
			.row
				.col-lg-8.offset-lg-2.col-xl-6.offset-xl-3
					.card.login-register-surface-card
						.card-body
							.page-header.login-register-page-header
								h1.login-register-header-heading-focus(style='font-family: Merriweather, serif; margin-bottom: 12.5px !important;') #{translate("password_reset")}
								.login-register-hr-text-container(style='margin-top: 1px; padding: 5px 0;')

							form(
								name='passwordResetForm'
								captcha-action-name=showCaptcha ? 'passwordReset' : false
								data-ol-async-form
								action='/user/password/reset'
								method='POST'
								captcha=showCaptcha ? '' : false
								style='margin-top: 0px !important;'
							)
								div(data-ol-not-sent)
									if error === 'password_reset_token_expired'
										+notification({
											ariaLive: 'assertive',
											type: 'error',
											className: 'mb-3',
											title: translate('sorry_your_token_expired'),
											content: translate('please_request_a_new_password_reset_email_and_follow_the_link') + '.'
										})
									else
										p(style='margin-top: 0px; margin-bottom: 15px !important; font-family: Lato, sans-serif; color: var(--content-primary-themed);')
											| #{translate("enter_your_email_address_below_and_we_will_send_you_a_link_to_reset_your_password")}.

									+formMessagesNewStyle
									if error && error !== 'password_reset_token_expired'
										+notification({ariaLive: 'assertive', type: 'error', className: 'mb-3', content: translate(error)})

									+customFormMessageNewStyle('no-password-allowed-due-to-sso', 'danger')
										| !{translate('you_cant_reset_password_due_to_sso', {}, [{name: 'a', attrs: {href: '/sso-login'}}])}

									input(name='_csrf' type='hidden' value=csrfToken)
									.form-group
										label(for='email' style='font-family: Lato, sans-serif; margin-bottom: 0.5em;') #{translate("email")}
										input#email.form-control(
											name='email'
											type='email'
											required
											placeholder='email@example.edu.cn'
											autocomplete='username'
											autofocus
											style='font-family: Lato, sans-serif !important; height: 45px !important; border-radius: 20px !important; padding: 10px 15px !important; border: 1px solid var(--border-primary-themed) !important; background-color: var(--bg-tertiary-themed) !important; color: var(--content-primary-themed) !important;'
										)
									.actions
										button.btn.btn-primary.w-100(
											type='submit'
											data-ol-disabled-inflight
											aria-label=translate('reset_password_sentence_case')
											style='font-family: Lato, sans-serif; padding: 10px 25px; border-radius: 20px;'
										)
											span(data-ol-inflight='idle')
												| #{translate("reset_password_sentence_case")}
											span(hidden data-ol-inflight='pending')
												| #{translate("requesting_password_reset")}…
										p.text-center(style='margin-top: 15px; margin-bottom: 0; font-family: Lato, sans-serif;')
											a(href='/login') #{translate("back_to_log_in")}

								div(hidden data-ol-sent)
									.notification.notification-type-success.auth-theme-success-notification.mb-3(role='status' aria-live='polite')
										.notification-icon
											+material-symbol('check_circle')
										.notification-content.text-left(style='font-family: Lato, sans-serif;')
											p #{translate('check_your_email')}
											p #{translate('password_reset_email_sent')}
									p.text-center(style='margin-bottom: 0; font-family: Lato, sans-serif;')
										a(href='/login') #{translate('back_to_log_in')}

							if showCaptcha
								+recaptchaConditions
