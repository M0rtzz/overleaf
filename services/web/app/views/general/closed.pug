extends ../layout-marketing

block vars
	- showThinFooter = true
	- additionalBodyClasses = [...new Set([...(Array.isArray(additionalBodyClasses) ? additionalBodyClasses : []), 'maintenance-page'])]

append css
	style.
		.maintenance-main {
			--maintenance-page-bg: var(--bg-secondary-themed);
			--maintenance-page-bg-alt: var(--bg-primary-themed);
			--maintenance-panel: var(--bg-primary-themed);
			--maintenance-panel-alt: var(--bg-secondary-themed);
			--maintenance-border: var(--border-divider-themed);
			--maintenance-text: var(--content-primary-themed);
			--maintenance-muted: var(--content-secondary-themed);
			--maintenance-shadow: 0 18px 42px rgba(27, 34, 44, 0.1);
			--status-operational-bg: #d6f1e2;
			--status-degraded-bg: #f9ead4;
			--status-maintenance-bg: #f5e4e4;
			--status-info-bg: #d6f1e2;
			--status-operational-dark-text: #098842;
			--maintenance-pill-bg: var(--status-maintenance-bg);
			--maintenance-pill-text: var(--content-danger-themed);
			--maintenance-link: #098842;
			background: var(--maintenance-page-bg);
			color: var(--maintenance-text);
			box-sizing: border-box;
			min-height: calc(100dvh - 50px);
			padding: calc(68px + 32px) 24px 32px;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--maintenance-page-bg);
		}

		.maintenance-shell {
			width: min(100%, 860px);
		}

		.maintenance-card {
			position: relative;
			overflow: hidden;
			padding: 36px;
			border-radius: 28px;
			border: 1px solid var(--maintenance-border);
			background: var(--maintenance-panel);
			box-shadow: var(--maintenance-shadow);
		}

		.maintenance-card::after {
			content: '';
			position: absolute;
			top: -88px;
			right: -72px;
			width: 240px;
			height: 240px;
			border-radius: 50%;
			background: rgba(0, 160, 84, 0.16);
			pointer-events: none;
		}

		.maintenance-content {
			position: relative;
			z-index: 1;
			display: grid;
			gap: 24px;
		}

		.maintenance-brand-lockup {
			display: inline-flex;
			flex-direction: column;
			align-items: center;
			gap: 8px;
		}

		.maintenance-brand-lockup .maintenance-eyebrow {
			text-align: center;
		}

		.maintenance-logo {
			width: 152px;
			height: 44px;
			object-fit: contain;
		}

		.maintenance-logo--light {
			display: none;
		}

		body[data-theme='light'] .maintenance-logo--dark {
			display: none;
		}

		body[data-theme='light'] .maintenance-logo--light {
			display: inline-block;
		}

		.maintenance-eyebrow {
			margin: 0;
			font-size: 13px;
			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--maintenance-muted);
		}

		.maintenance-pill,
		.maintenance-notice-meta {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 8px 14px;
			border-radius: 999px;
			font-size: 13px;
			font-weight: 700;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

		.maintenance-pill {
			justify-self: center;
			background: var(--maintenance-pill-bg);
			color: var(--maintenance-pill-text);
		}

		.maintenance-title-block {
			display: grid;
			gap: 12px;
			text-align: center;
		}

		.maintenance-title {
			margin: 0;
			font-size: clamp(34px, 5vw, 54px);
			line-height: 1.12;
			color: var(--maintenance-text);
		}

		.maintenance-summary {
			max-width: 640px;
			margin: 0 auto;
			font-size: 18px;
			line-height: 1.7;
			color: var(--maintenance-muted);
		}

		.maintenance-notice,
		.maintenance-support {
			padding: 24px 28px;
			border-radius: 22px;
			border: 1px solid var(--maintenance-border);
			background: var(--maintenance-panel-alt);
		}

		.maintenance-notice-head,
		.maintenance-support-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 16px;
			margin-bottom: 12px;
		}

		.maintenance-notice-title,
		.maintenance-support-title {
			margin: 0;
			font-size: 21px;
			color: var(--maintenance-text);
		}

		.maintenance-notice-meta {
			background: var(--maintenance-pill-bg);
			color: var(--maintenance-pill-text);
			padding: 6px 10px;
			font-size: 12px;
		}

		.maintenance-notice-copy,
		.maintenance-support-copy,
		.maintenance-html-message,
		.maintenance-html-message p {
			margin: 0;
			font-size: 16px;
			line-height: 1.7;
			color: var(--maintenance-muted);
		}

		.maintenance-html-message > :first-child {
			margin-top: 0;
		}

		.maintenance-html-message > :last-child {
			margin-bottom: 0;
		}

		.maintenance-link,
		.maintenance-link:visited,
		.maintenance-link:hover,
		.maintenance-link:focus,
		.maintenance-html-message a,
		.maintenance-html-message a:visited,
		.maintenance-html-message a:hover,
		.maintenance-html-message a:focus {
			color: var(--maintenance-link);
			text-decoration: underline;
			text-decoration-thickness: 1px;
			text-underline-offset: 3px;
		}

		.maintenance-actions {
			margin-top: 18px;
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.maintenance-actions .maintenance-action {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 42px;
			padding: 0 16px;
			border-radius: 999px;
			border: 1px solid var(--maintenance-border);
			background: var(--maintenance-panel);
			color: var(--maintenance-text);
			font-size: 13px;
			font-weight: 700;
			letter-spacing: 0.04em;
			text-decoration: none;
			text-transform: uppercase;
		}

		.maintenance-actions .maintenance-action:visited,
		.maintenance-actions .maintenance-action:hover,
		.maintenance-actions .maintenance-action:focus {
			color: var(--maintenance-text);
			background: var(--maintenance-page-bg);
			text-decoration: none;
		}

		.maintenance-actions .maintenance-action--primary,
		.maintenance-actions .maintenance-action--primary:visited {
			border-color: transparent;
			background: var(--bg-accent-01);
			color: #fff;
			text-decoration: none;
		}

		.maintenance-actions .maintenance-action--primary:hover,
		.maintenance-actions .maintenance-action--primary:focus {
			background: var(--bg-accent-02);
			color: #fff;
			text-decoration: none;
		}

		@media (max-width: 640px) {
			.maintenance-main {
				padding: calc(68px + 24px) 16px 24px;
			}

			.maintenance-card {
				padding: 24px;
				border-radius: 24px;
			}

			.maintenance-notice,
			.maintenance-support {
				padding: 20px;
				border-radius: 18px;
			}

			.maintenance-logo {
				width: 132px;
			}

			.maintenance-notice-head,
			.maintenance-support-head {
				align-items: flex-start;
				flex-wrap: wrap;
			}

			.maintenance-actions {
				flex-direction: column;
			}

			.maintenance-actions .maintenance-action {
				width: 100%;
			}
		}

block content
	- var statusPageHref = settings.statusPageUrl || '/site-status'
	- var statusPageIsExternal = /^https?:\/\//.test(statusPageHref)
	main#main-content.content.content-alt.sessions-page.maintenance-main
		.maintenance-shell
			section.maintenance-card(aria-labelledby='maintenance-title')
				.maintenance-content
					.maintenance-brand-lockup
						img.maintenance-logo.maintenance-logo--dark(
							src=buildImgPath('ol-brand/overleaf-white.svg')
							alt=settings.appName
						)
						img.maintenance-logo.maintenance-logo--light(
							src=buildImgPath('ol-brand/overleaf-green.svg')
							alt=settings.appName
						)
						p.maintenance-eyebrow Website status
					span.maintenance-pill Maintenance
					.maintenance-title-block
						h1#maintenance-title.maintenance-title Maintenance in progress
						p.maintenance-summary
							| We&apos;re performing scheduled work right now. Logging in,
							|  projects, or the editor may be temporarily limited until service is restored.
					section.maintenance-notice(aria-labelledby='maintenance-notice-title')
						.maintenance-notice-head
							h2#maintenance-notice-title.maintenance-notice-title Current notice
							span.maintenance-notice-meta Maintenance
						if settings.maintenanceMessageHTML
							.maintenance-html-message !{settings.maintenanceMessageHTML}
						else if settings.maintenanceMessage
							p.maintenance-notice-copy= settings.maintenanceMessage
						else
							p.maintenance-notice-copy
								| Service access is temporarily unavailable while scheduled work is completed.
								|  Please check
								= ' '
								a.maintenance-link(
									href=statusPageHref
									target=statusPageIsExternal ? '_blank' : undefined
									rel=statusPageIsExternal ? 'noreferrer' : undefined
								) the status page
								|  for updates.
								if settings.adminEmail
									|  If you need urgent help, contact
									= ' '
									a.maintenance-link(href='mailto:' + settings.adminEmail) the support team
									| .
					section.maintenance-support(aria-labelledby='maintenance-support-title')
						.maintenance-support-head
							h2#maintenance-support-title.maintenance-support-title Need help?
						p.maintenance-support-copy
							if settings.adminEmail
								| Contact
								= ' '
								a.maintenance-link(href='mailto:' + settings.adminEmail) the support team
								|  if you need help restoring access or confirming whether maintenance is still active.
							else
								| Check the status page for the latest maintenance updates.
						.maintenance-actions
							a.maintenance-action.maintenance-action--primary(
								href=statusPageHref
								target=statusPageIsExternal ? '_blank' : undefined
								rel=statusPageIsExternal ? 'noreferrer' : undefined
							) View status page
